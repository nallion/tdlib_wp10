<Page
    x:Class="TelegramClient.ChatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TelegramClient.Services">

    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="#0F3460" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Сообщения"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#E94560" FontSize="24"
                    Content="&#xE71E;"
                    FontFamily="Segoe MDL2 Assets"
                    Click="OnSearch"/>
        </Grid>

        <!-- Список чатов -->
        <ListView x:Name="ChatsList"
                  Grid.Row="1"
                  Background="Transparent"
                  SelectionMode="Single"
                  ItemClick="OnChatClick"
                  IsItemClickEnabled="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="16,12" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар -->
                        <Ellipse Width="46" Height="46" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E94560" Offset="0"/>
                                    <GradientStop Color="#0F3460" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="{Binding AvatarLetter}"
                                   Foreground="White"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Текст -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="White"
                                       FontSize="16" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LastMessage}"
                                       Foreground="#8899AA"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- Разделитель -->
                        <Rectangle Grid.Column="1"
                                   Height="0.5"
                                   Fill="#0F3460"
                                   VerticalAlignment="Bottom"
                                   Margin="12,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Пустое состояние -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="&#xE8BD;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="64" Foreground="#0F3460"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Нет чатов"
                       Foreground="#8899AA"
                       FontSize="16"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Загрузка -->
        <ProgressRing x:Name="Loader"
                      Grid.Row="1"
                      IsActive="True"
                      Foreground="#E94560"
                      Width="48" Height="48"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"/>
    </Grid>
</Page>
