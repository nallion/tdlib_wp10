<Page
    x:Class="TelegramClient.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1A1A2E">

    <Page.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"           Value="#16213E"/>
            <Setter Property="Foreground"           Value="White"/>
            <Setter Property="BorderBrush"          Value="#0F3460"/>
            <Setter Property="BorderThickness"      Value="0,0,0,2"/>
            <Setter Property="FontSize"             Value="18"/>
            <Setter Property="Padding"              Value="0,8"/>
            <Setter Property="Margin"               Value="0,0,0,20"/>
            <Setter Property="SelectionHighlightColor" Value="#E94560"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#E94560"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="16"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Height"           Value="50"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Margin"           Value="0,10,0,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#16213E" Offset="0.5"/>
                <GradientStop Color="#0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" Margin="40,0">

            <!-- Логотип -->
            <Viewbox Width="72" Height="72" Margin="0,0,0,24" HorizontalAlignment="Center">
                <Canvas Width="100" Height="100">
                    <Ellipse Width="100" Height="100" Fill="#E94560"/>
                    <Path Fill="White" Data="M 30,35 L 70,35 L 70,55 L 55,55 L 50,65 L 45,55 L 30,55 Z"/>
                </Canvas>
            </Viewbox>

            <TextBlock Text="Telegram"
                       FontSize="28" FontWeight="Light"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="SubtitleText"
                       Text="Войдите в свой аккаунт"
                       FontSize="14"
                       Foreground="#8899AA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Шаг 1: Телефон -->
            <StackPanel x:Name="PhonePanel">
                <TextBlock Text="Номер телефона" Foreground="#8899AA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox x:Name="PhoneBox"
                         Style="{StaticResource InputStyle}"
                         PlaceholderText="+7 900 000 00 00"
                         InputScope="TelephoneNumber"/>
                <Button Content="Продолжить"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnSendPhone"/>
            </StackPanel>

            <!-- Шаг 2: Код -->
            <StackPanel x:Name="CodePanel" Visibility="Collapsed">
                <TextBlock Text="Код из SMS / Telegram" Foreground="#8899AA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox x:Name="CodeBox"
                         Style="{StaticResource InputStyle}"
                         PlaceholderText="12345"
                         InputScope="NumericPin"
                         MaxLength="6"/>
                <Button Content="Подтвердить код"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnSendCode"/>
            </StackPanel>

            <!-- Шаг 3: Пароль 2FA -->
            <StackPanel x:Name="PasswordPanel" Visibility="Collapsed">
                <TextBlock Text="Пароль двухфакторной аутентификации"
                           Foreground="#8899AA" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Background="#16213E"
                             Foreground="White"
                             BorderBrush="#0F3460"
                             BorderThickness="0,0,0,2"
                             FontSize="18"
                             Padding="0,8"
                             Margin="0,0,0,20"
                             PlaceholderText="Ваш пароль"/>
                <Button Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnSendPassword"/>
            </StackPanel>

            <!-- Индикатор загрузки -->
            <ProgressRing x:Name="Loader"
                          IsActive="False"
                          Foreground="#E94560"
                          Width="40" Height="40"
                          Margin="0,20,0,0"
                          HorizontalAlignment="Center"/>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#E94560"
                       FontSize="13"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>
