<Page
    x:Class="TelegramClient.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TelegramClient.Services">

    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка чата -->
        <Grid Grid.Row="0" Background="#0F3460" Padding="8,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Background="Transparent" BorderThickness="0"
                    Foreground="White" FontSize="20"
                    Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                    Padding="8,0" Click="OnBack"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock x:Name="ChatTitle"
                           Foreground="White"
                           FontSize="18" FontWeight="SemiBold"/>
                <TextBlock x:Name="ChatStatus"
                           Text="в сети"
                           Foreground="#E94560"
                           FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- Список сообщений -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  Background="Transparent"
                  SelectionMode="None"
                  Padding="8,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <!-- Входящие слева, исходящие справа через триггер -->
                    <Grid x:Name="MsgGrid">
                        <Border x:Name="MsgBubble"
                                MaxWidth="280"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="White"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}"
                                           FontSize="11"
                                           Foreground="#AABBCC"
                                           HorizontalAlignment="Right"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState x:Name="Outgoing">
                                    <VisualState.StateTriggers>
                                        <StateTrigger IsActive="{Binding IsOutgoing}"/>
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="MsgBubble.Background"  Value="#E94560"/>
                                        <Setter Target="MsgBubble.HorizontalAlignment" Value="Right"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Incoming">
                                    <VisualState.Setters>
                                        <Setter Target="MsgBubble.Background"  Value="#16213E"/>
                                        <Setter Target="MsgBubble.HorizontalAlignment" Value="Left"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Поле ввода -->
        <Grid Grid.Row="2" Background="#16213E" Padding="8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Background="#0F3460"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="16"
                     Padding="12,10"
                     CornerRadius="20"
                     PlaceholderText="Сообщение..."
                     TextWrapping="Wrap"
                     MaxHeight="120"
                     KeyDown="OnInputKeyDown"/>

            <Button Grid.Column="1"
                    x:Name="SendButton"
                    Background="#E94560"
                    BorderThickness="0"
                    Width="48" Height="48"
                    Margin="8,0,0,0"
                    CornerRadius="24"
                    Click="OnSend">
                <TextBlock Text="&#xE724;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="White"/>
            </Button>
        </Grid>
    </Grid>
</Page>
