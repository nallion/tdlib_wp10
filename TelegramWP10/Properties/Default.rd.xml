<Directives xmlns="http://schemas.microsoft.com/netfx/2013/01/metadata">
  <Application>
    <!-- Сохраняем метаданные приложения -->
    <Assembly Name="TelegramWP10" Dynamic="Required All" />

    <!-- SkiaSharp — нужна рефлексия для P/Invoke и нативных типов -->
    <Assembly Name="SkiaSharp" Dynamic="Required All" />

    <!-- Newtonsoft.Json — использует рефлексию для сериализации -->
    <Assembly Name="Newtonsoft.Json" Dynamic="Required All" />

    <!-- Системные сборки для Task/async -->
    <Assembly Name="System.Runtime" Dynamic="Required All" />
    <Assembly Name="System.Threading.Tasks" Dynamic="Required All" />
  </Application>
</Directives>
