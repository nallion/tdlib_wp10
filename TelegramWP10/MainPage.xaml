<Page
    x:Class="TelegramWP10.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TelegramWP10"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Невидимый хост для воспроизведения аудио -->
        <StackPanel x:Name="AudioPlayerHost" Visibility="Collapsed" Width="0" Height="0"/>
        <Grid x:Name="StartPanel" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="LoginPanel" Grid.Row="0" Visibility="Visible" Margin="0,0,0,10">
                <TextBlock x:Name="LoginStatus" Text="" Foreground="#0088cc" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <TextBox x:Name="PhoneInput" Header="Телефон" PlaceholderText="+7..." InputScope="TelephoneNumber"/>
                <Button x:Name="PhoneButton" Content="Далее" Click="SendPhone_Click" HorizontalAlignment="Stretch" Margin="0,10"/>
                <TextBox x:Name="CodeInput" Header="Код из Unogram" Visibility="Collapsed" Margin="0,10"/>
                <Button x:Name="CodeButton" Content="Войти" Click="SendCode_Click" Visibility="Collapsed" HorizontalAlignment="Stretch"/>
                <PasswordBox x:Name="PasswordInput" Header="Пароль 2FA" Visibility="Collapsed" Margin="0,10"/>
                <Button x:Name="PasswordButton" Content="Подтвердить" Click="SendPassword_Click" Visibility="Collapsed" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <ListView x:Name="ChatListView" Grid.Row="1" Visibility="Collapsed" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ChatListView_ItemClick">
                <ListView.Header>
                    <StackPanel Background="#1A1A1A">
                        <!-- Шапка главного списка -->
                        <StackPanel x:Name="MainListHeader">
                            <TextBlock Text="Unogram" Foreground="White" FontSize="28" FontWeight="Bold" Margin="15,15,15,2"/>
                            <StackPanel Orientation="Horizontal" Margin="15,0,15,10">
                                <TextBlock Text="Чатов: " Foreground="#888888" FontSize="13"/>
                                <TextBlock x:Name="ChatCountText" Text="0" Foreground="#888888" FontSize="13"/>
                                <TextBlock x:Name="ConnectionStatusText" Text="" Foreground="#FF6666" FontSize="13" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Шапка архива -->
                        <StackPanel x:Name="ArchiveListHeader" Visibility="Collapsed">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ArchiveBackButton" Content="←" Click="ArchiveBack_Click"
                                        Background="Transparent" Foreground="White" FontSize="22"
                                        Padding="10,4,8,4" VerticalAlignment="Center" BorderThickness="0"/>
                                <TextBlock Grid.Column="1" Text="Архив" Foreground="White"
                                           FontSize="26" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                            </Grid>
                            <TextBlock x:Name="ArchiveChatCountText" Text="" Foreground="#888888"
                                       FontSize="13" Margin="15,0,15,10"/>
                        </StackPanel>
                        <!-- Строка "Архив" (в главном списке) -->
                        <Border x:Name="ArchiveRow" Background="#222222" Tapped="ArchiveRow_Tapped"
                                Margin="0,2,0,0" Padding="0">
                            <Grid Margin="15,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Иконка папки -->
                                <Border Width="42" Height="42" CornerRadius="21"
                                        Background="#444444" HorizontalAlignment="Left">
                                    <TextBlock Text="📁" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Архив" Foreground="White"
                                               FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ArchiveSubtitleText" Text="архивированные чаты"
                                               Foreground="#888888" FontSize="13"
                                               TextTrimming="CharacterEllipsis" MaxLines="1" TextWrapping="NoWrap"/>
                                </StackPanel>
                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <!-- Бейдж непрочитанных -->
                                    <Border x:Name="ArchiveUnreadBadge" Background="#888888"
                                            CornerRadius="10" MinWidth="20" Height="20"
                                            Padding="5,0" HorizontalAlignment="Right"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="ArchiveUnreadText" Text="0"
                                                   Foreground="White" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Стрелка (когда нет непрочитанных) -->
                                    <TextBlock x:Name="ArchiveArrow" Text="›" Foreground="#888888"
                                               FontSize="20" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Margin="0,0,2,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6" Holding="ChatItem_Holding">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="MenuPinChat" Text="📌 Закрепить" Click="PinChat_Click"/>
                                    <MenuFlyoutItem x:Name="MenuArchiveChat" Text="📁 Переместить в архив" Click="ArchiveChat_Click"/>
                                    <MenuFlyoutItem Text="🗑 Удалить переписку" Click="DeleteChat_Click"/>
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="60" VerticalAlignment="Top">
                                <Border Width="50" Height="50" CornerRadius="25" Background="#555555" BorderThickness="0" HorizontalAlignment="Left">
                                    <Image Source="{Binding Photo}" Stretch="UniformToFill" Width="50" Height="50"/>
                                </Border>
                                <Ellipse Width="14" Height="14" Fill="#22C55E"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,2,0"
                                         Visibility="{Binding OnlineVisibility}"/>
                            </Grid>
                            <Grid Grid.Column="1" Margin="5,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Строка 1: название + время -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📌 " FontSize="12" Foreground="#888888"
                                                   Visibility="{Binding PinVisibility}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding LastMessageTime}" Foreground="#888888" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                                <!-- Строка 2: последнее сообщение + бейдж непрочитанных -->
                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding LastMessage}" Foreground="#888888" FontSize="13" TextTrimming="CharacterEllipsis" MaxLines="1" TextWrapping="NoWrap" Margin="0,0,40,0"/>
                                    <!-- Галочки для исходящих -->
                                    <TextBlock Text="{Binding StatusText}" Foreground="#0088cc" FontSize="13"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Visibility="{Binding StatusVisibility}"/>
                                    <!-- Бейдж непрочитанных для входящих -->
                                    <Border Background="#0088cc" CornerRadius="10" MinWidth="20" Height="20"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Visibility="{Binding UnreadVisibility}" Padding="4,0">
                                        <TextBlock Text="{Binding UnreadText}" Foreground="White" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button x:Name="LogoutButton" Grid.Row="2" Content="Выход" Click="LogoutButton_Click"
                    HorizontalAlignment="Stretch" Margin="0,8,0,0"
                    Background="#AA222222" Foreground="#FF4444"
                    Visibility="Collapsed"/>
        </Grid>

        <Grid x:Name="MessagesPanel" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Background="#0088cc" Padding="10">
                <Button Content="←" Click="BackButton_Click" Foreground="White" Background="Transparent" FontSize="20"/>
                <StackPanel VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="CurrentChatTitle" Text="Чат" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CurrentChatStatus" Text="" Foreground="#CCE8FF" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <ListView x:Name="MessagesListView" Grid.Row="1" SelectionMode="None" Padding="10" IsItemClickEnabled="True" ItemClick="MessagesListView_ItemClick" Visibility="Collapsed">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- Разделитель дат -->
                            <Border Visibility="{Binding SeparatorVisibility}" HorizontalAlignment="Stretch" Margin="0,6,0,6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border Background="#44FFFFFF" CornerRadius="10" Padding="12,4">
                                        <TextBlock Text="{Binding SeparatorLabel}" FontSize="12" Foreground="#CCFFFFFF" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <!-- Пузырь сообщения -->
                            <Border Background="{Binding BubbleBackground}" Padding="8,5" Margin="0,4" CornerRadius="10" HorizontalAlignment="{Binding Alignment}"
                                    Visibility="{Binding MessageVisibility}"
                                    Holding="MessageBubble_Holding">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="↩ Ответить" Click="ReplyMessage_Click"/>
                                    <MenuFlyoutItem Text="↪ Переслать" Click="ForwardMessage_Click"/>
                                    <MenuFlyoutItem Text="📋 Копировать текст" Click="CopyMessage_Click"/>
                                    <MenuFlyoutItem x:Name="MenuEdit" Text="✏ Редактировать" Click="EditMessage_Click"/>
                                    <MenuFlyoutItem x:Name="MenuDeleteSelf" Text="🗑 Удалить сообщение" Click="DeleteMessageSelf_Click"/>
                                    <MenuFlyoutItem x:Name="MenuDeleteAll" Text="🗑 Удалить у всех" Click="DeleteMessageAll_Click"/>
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <StackPanel MaxWidth="260">
                                <!-- Ник отправителя (только входящие в группах) -->
                                <TextBlock Text="{Binding SenderName}" FontSize="12" FontWeight="Bold"
                                           Foreground="{Binding SenderColor}"
                                           Visibility="{Binding SenderNameVisibility}"
                                           Margin="0,0,0,3"/>

                                <!-- Переслано от -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding ForwardedVisibility}" Margin="0,0,0,4">
                                    <TextBlock Text="↪ " Foreground="#7EC8E3" FontSize="12"/>
                                    <TextBlock Text="{Binding ForwardedFrom}" Foreground="#7EC8E3" FontSize="12"
                                               FontStyle="Italic" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                </StackPanel>

                                <!-- Цитата -->
                                <Border Background="#44000000" BorderBrush="#88FFFFFF" BorderThickness="2,0,0,0" Margin="0,0,0,5" Padding="5,2" Visibility="{Binding ReplyVisibility}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ReplyAuthor}" FontSize="11" FontWeight="Bold"
                                                   Foreground="#7EC8E3" Visibility="{Binding ReplyAuthorVisibility}"/>
                                        <TextBlock Text="{Binding ReplyToText}" FontSize="12" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                    </StackPanel>
                                </Border>

                                <!-- Фото / Видео (превью + иконка воспроизведения) -->
                                <Grid Visibility="{Binding PhotoVisibility}" Margin="0,0,0,5">
                                    <Image Source="{Binding AttachedPhoto}" Stretch="Uniform" MaxWidth="250"
                                           Tapped="PhotoImage_Tapped"/>
                                    <TextBlock Text="▶" Foreground="White" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Visibility="{Binding VideoIconVisibility}" Opacity="0.8" IsHitTestVisible="False"/>
                                    <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Background="#88000000" Padding="6,2"
                                            Visibility="{Binding VideoProgressVisibility}">
                                        <TextBlock Text="{Binding VideoDownloadProgress}" Foreground="White"
                                                   FontSize="14" FontWeight="Bold" IsHitTestVisible="False"/>
                                    </Border>
                                </Grid>

                                <!-- GIF: MediaElement авто-воспроизведение (без превью) -->
                                <Grid Visibility="{Binding GifPlayerVisibility}" Margin="0,0,0,5"
                                      MaxWidth="250" Tapped="PhotoImage_Tapped">
                                    <MediaElement x:Name="GifPlayer"
                                                  Source="{Binding GifSource}"
                                                  AutoPlay="True" IsLooping="True"
                                                  IsMuted="True" AreTransportControlsEnabled="False"
                                                  Stretch="Uniform" MaxWidth="250"/>
                                    <!-- Прогресс скачивания GIF -->
                                    <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Background="#88000000" Padding="6,2"
                                            Visibility="{Binding VideoProgressVisibility}">
                                        <TextBlock Text="{Binding VideoDownloadProgress}" Foreground="White"
                                                   FontSize="14" FontWeight="Bold" IsHitTestVisible="False"/>
                                    </Border>
                                </Grid>

                                <!-- Документ -->
                                <Border Visibility="{Binding DocumentVisibility}" Background="#22FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,0,0,5">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📄" FontSize="28" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DocumentName}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DocumentSize}" Foreground="#AAAAAA" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                        <Button Content="{Binding DownloadStatus}" Tag="{Binding Id}" Click="DocumentButton_Click"
                                                Margin="0,6,0,0" HorizontalAlignment="Stretch"
                                                Background="#0088cc" Foreground="White" FontSize="12" Padding="6,4"/>
                                    </StackPanel>
                                </Border>

                                <!-- Аудио -->
                                <Border Visibility="{Binding AudioVisibility}" Background="#22FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{Binding AudioPlayStatus}" Tag="{Binding Id}" Click="AudioButton_Click"
                                                Width="40" Height="40" Background="#0088cc" Foreground="White" FontSize="16"
                                                Padding="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AudioTitle}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <Slider Tag="{Binding Id}" Minimum="0" Maximum="{Binding AudioDurationSeconds}"
                                                    Value="{Binding AudioPosition, Mode=OneWay}"
                                                    ManipulationMode="All"
                                                    ManipulationStarted="AudioSlider_ManipulationStarted"
                                                    ManipulationCompleted="AudioSlider_ManipulationCompleted"
                                                    Margin="0,2,0,0" Padding="0" Height="20"
                                                    Foreground="#0088cc"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding AudioPositionText}" Foreground="#AAAAAA" FontSize="11"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AudioDuration}" Foreground="#AAAAAA" FontSize="11"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <RichTextBlock x:Name="MsgTextBlock" TextWrapping="Wrap" Foreground="White" FontSize="16"
                                               Tag="{Binding Id}" Loaded="MsgRichText_Loaded" DataContextChanged="MsgRichText_DataContextChanged"/>
                                <!-- Дата + галочки -->
                                <Grid HorizontalAlignment="Right" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Date}" FontSize="10" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ReadStatusText}" FontSize="10" Margin="4,0,0,0"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Visibility="{Binding ReadStatusVisibility}"/>
                                </Grid>
                                <!-- Реакции -->
                                <Border Visibility="{Binding ReactionsVisibility}" Background="#22FFFFFF" CornerRadius="10" Padding="6,3" Margin="0,4,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Reactions}" FontSize="14"/>
                                </Border>
                                <!-- Inline-кнопки -->
                                <ItemsControl ItemsSource="{Binding InlineButtons}" Visibility="{Binding InlineButtonsVisibility}" Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <ItemsControl ItemsSource="{Binding Buttons}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding Text}"
                                                                    Tag="{Binding}"
                                                                    Click="InlineButton_Click"
                                                                    Margin="0,0,4,0"
                                                                    Padding="10,5"
                                                                    Background="#2A6496"
                                                                    Foreground="White"
                                                                    FontSize="12"
                                                                    MinWidth="60"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="1" x:Name="LoadingIndicator" Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="60" Height="60" Foreground="#0088cc" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="Загрузка..." Foreground="#888888" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0"/>
            </Grid>

            <StackPanel Grid.Row="2">
                <!-- Панель предпросмотра цитаты -->
                <Grid x:Name="ReplyPreviewPanel" Visibility="Collapsed" Background="#1A1A1A" Padding="10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="↩ Ответить" Foreground="#0088cc" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ReplyPreviewText" Text="" Foreground="#AAAAAA" FontSize="12"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Click="CancelReply_Click"
                            Background="Transparent" Foreground="#888888" FontSize="14"
                            Width="36" Height="36" Padding="0"/>
                </Grid>

                <Grid x:Name="InputGrid" Padding="10" Background="#222222">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="📎" Click="AttachFile_Click" Width="44" Height="40"
                        Background="Transparent" Foreground="White" FontSize="18" Padding="0"/>
                <Border x:Name="MicButton" Grid.Column="1" Width="44" Height="40"
                        Background="Transparent" CornerRadius="8"
                        PointerPressed="MicButton_PointerPressed" PointerReleased="MicButton_PointerReleased"
                        PointerExited="MicButton_PointerReleased">
                    <TextBlock Text="🎤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBox x:Name="MessageInput" Grid.Column="2" PlaceholderText="Сообщение..." AcceptsReturn="True" MaxHeight="100" Margin="8,0"
                         Holding="MessageInput_Holding">
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Вставить текст" Click="PasteToInput_Click"/>
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </TextBox>
                <Button x:Name="SendButton" Grid.Column="3" Content="➤" Click="SendMessage_Click" Width="50" Height="40" Background="#0088cc" Foreground="White"/>
            </Grid>
            </StackPanel>
        </Grid>

        <!-- Оверлей выбора чата для пересылки -->
        <Grid x:Name="ForwardOverlay" Visibility="Collapsed" Background="#DD000000"
              Grid.Row="0" Grid.RowSpan="2">
            <Border Background="#222222" CornerRadius="12" Margin="20,60"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Шапка -->
                    <Grid Background="#0088cc" Padding="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Переслать в чат" Foreground="White" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" Click="ForwardOverlay_Close"
                                Background="Transparent" Foreground="White" FontSize="16" Width="40" Height="40" Padding="0"/>
                    </Grid>
                    <!-- Список чатов -->
                    <ListView x:Name="ForwardChatList" Grid.Row="1"
                              SelectionMode="None" IsItemClickEnabled="True"
                              ItemClick="ForwardChatList_ItemClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#555555" Margin="0,0,12,0">
                                        <Image Source="{Binding Photo}" Stretch="UniformToFill" Width="40" Height="40"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Полноэкранный просмотр фото -->
        <Grid x:Name="PhotoOverlay" Visibility="Collapsed" Background="#DD000000"
              Grid.Row="0" Grid.RowSpan="2">
            <ScrollViewer ZoomMode="Enabled" MinZoomFactor="1" MaxZoomFactor="5"
                          HorizontalScrollMode="Enabled" VerticalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid Width="{Binding ActualWidth, ElementName=PhotoOverlay}"
                      Height="{Binding ActualHeight, ElementName=PhotoOverlay}">
                    <Image x:Name="PhotoOverlayImage" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </ScrollViewer>
            <Button Content="✕" Click="PhotoOverlay_Tapped"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,8,0" Width="44" Height="44"
                    Background="#88000000" Foreground="White" FontSize="18" Padding="0"/>
            <TextBlock x:Name="PhotoOverlayStatus" Text="" Foreground="White"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                       FontSize="14" Margin="0,0,0,16"/>
        </Grid>
    </Grid>
</Page>
