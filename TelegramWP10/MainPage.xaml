<Page x:Class="TelegramWP10.MainPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel VerticalAlignment="Center" Padding="20">
            <TextBox x:Name="PhoneInput" Header="Phone Number" PlaceholderText="+7..." InputScope="TelephoneNumber"/>
            <Button Content="Send SMS Code" Click="SendCode_Click" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
            <TextBlock x:Name="StatusText" Margin="0,10" Text="Status: Ready" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>
