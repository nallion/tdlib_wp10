<Page
    x:Class="TelegramWP10.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TelegramWP10"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Невидимый хост для воспроизведения аудио -->
        <StackPanel x:Name="AudioPlayerHost" Visibility="Collapsed" Width="0" Height="0"/>
        <Grid x:Name="StartPanel" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="LoginPanel" Grid.Row="0" Visibility="Visible" Margin="0,0,0,10">
                <TextBlock x:Name="LoginStatus" Text="" Foreground="#0088cc" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <TextBox x:Name="PhoneInput" Header="Телефон" PlaceholderText="+7..." InputScope="TelephoneNumber"/>
                <Button x:Name="PhoneButton" Content="Далее" Click="SendPhone_Click" HorizontalAlignment="Stretch" Margin="0,10"/>
                <TextBox x:Name="CodeInput" Header="Код из Unogram" Visibility="Collapsed" Margin="0,10"/>
                <Button x:Name="CodeButton" Content="Войти" Click="SendCode_Click" Visibility="Collapsed" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <ListView x:Name="ChatListView" Grid.Row="1" Visibility="Collapsed" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ChatListView_ItemClick">
                <ListView.Header>
                    <StackPanel Background="#1A1A1A">
                        <TextBlock Text="Unogram" Foreground="White" FontSize="28" FontWeight="Bold" Margin="15,15,15,2"/>
                        <StackPanel Orientation="Horizontal" Margin="15,0,15,10">
                            <TextBlock Text="Чатов: " Foreground="#888888" FontSize="13"/>
                            <TextBlock x:Name="ChatCountText" Text="0" Foreground="#888888" FontSize="13"/>
                        </StackPanel>
                        <Border x:Name="ConnectionStatus" Background="#CC880000" Padding="10,6" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="ConnectionStatusText" Text="Подключение..." Foreground="White" FontSize="13" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6" Holding="ChatItem_Holding">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="🗑 Удалить переписку" Click="DeleteChat_Click"/>
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="60" VerticalAlignment="Top">
                                <Border Width="50" Height="50" CornerRadius="25" Background="#555555" BorderThickness="0" HorizontalAlignment="Left">
                                    <Image Source="{Binding Photo}" Stretch="UniformToFill" Width="50" Height="50"/>
                                </Border>
                                <Ellipse Width="14" Height="14" Fill="#22C55E"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,2,0"
                                         Visibility="{Binding OnlineVisibility}"/>
                            </Grid>
                            <Grid Grid.Column="1" Margin="5,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Строка 1: название + время -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastMessageTime}" Foreground="#888888" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                                <!-- Строка 2: последнее сообщение + бейдж непрочитанных -->
                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding LastMessage}" Foreground="#888888" FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/>
                                    <!-- Галочки для исходящих -->
                                    <TextBlock Text="{Binding StatusText}" Foreground="#0088cc" FontSize="13"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Visibility="{Binding StatusVisibility}"/>
                                    <!-- Бейдж непрочитанных для входящих -->
                                    <Border Background="#0088cc" CornerRadius="10" MinWidth="20" Height="20"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Visibility="{Binding UnreadVisibility}" Padding="4,0">
                                        <TextBlock Text="{Binding UnreadText}" Foreground="White" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button x:Name="LogoutButton" Grid.Row="2" Content="Выход" Click="LogoutButton_Click"
                    HorizontalAlignment="Stretch" Margin="0,8,0,0"
                    Background="#AA222222" Foreground="#FF4444"
                    Visibility="Collapsed"/>
        </Grid>

        <Grid x:Name="MessagesPanel" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Background="#0088cc" Padding="10">
                <Button Content="←" Click="BackButton_Click" Foreground="White" Background="Transparent" FontSize="20"/>
                <StackPanel VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="CurrentChatTitle" Text="Чат" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CurrentChatStatus" Text="" Foreground="#CCE8FF" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <ListView x:Name="MessagesListView" Grid.Row="1" SelectionMode="None" Padding="10" IsItemClickEnabled="True" ItemClick="MessagesListView_ItemClick" Visibility="Collapsed">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Background}" Padding="8,5" Margin="0,4" CornerRadius="10" HorizontalAlignment="{Binding Alignment}">
                            <StackPanel MaxWidth="260">
                                <Border Background="#44000000" BorderBrush="#88FFFFFF" BorderThickness="2,0,0,0" Margin="0,0,0,5" Padding="5,2" Visibility="{Binding ReplyVisibility}">
                                    <TextBlock Text="{Binding ReplyToText}" FontSize="12" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                </Border>

                                <Grid Visibility="{Binding PhotoVisibility}" Margin="0,0,0,5">
                                    <Image Source="{Binding AttachedPhoto}" Stretch="Uniform" MaxWidth="250"/>
                                    <TextBlock Text="▶" Foreground="White" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding VideoIconVisibility}" Opacity="0.8" IsHitTestVisible="False"/>
                                </Grid>

                                <!-- Документ -->
                                <Border Visibility="{Binding DocumentVisibility}" Background="#22FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,0,0,5">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📄" FontSize="28" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DocumentName}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DocumentSize}" Foreground="#AAAAAA" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                        <Button Content="{Binding DownloadStatus}" Tag="{Binding Id}" Click="DocumentButton_Click"
                                                Margin="0,6,0,0" HorizontalAlignment="Stretch"
                                                Background="#0088cc" Foreground="White" FontSize="12" Padding="6,4"/>
                                    </StackPanel>
                                </Border>

                                <!-- Аудио -->
                                <Border Visibility="{Binding AudioVisibility}" Background="#22FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{Binding AudioPlayStatus}" Tag="{Binding Id}" Click="AudioButton_Click"
                                                Width="40" Height="40" Background="#0088cc" Foreground="White" FontSize="16"
                                                Padding="0" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AudioTitle}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding AudioDuration}" Foreground="#AAAAAA" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White" FontSize="16"/>
                                <!-- Дата + галочки -->
                                <Grid HorizontalAlignment="Right" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Date}" FontSize="10" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ReadStatusText}" FontSize="10" Margin="4,0,0,0"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Visibility="{Binding ReadStatusVisibility}"/>
                                </Grid>
                                <!-- Реакции -->
                                <Border Visibility="{Binding ReactionsVisibility}" Background="#22FFFFFF" CornerRadius="10" Padding="6,3" Margin="0,4,0,0" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Reactions}" FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="1" x:Name="LoadingIndicator" Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="60" Height="60" Foreground="#0088cc" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="Загрузка..." Foreground="#888888" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0"/>
            </Grid>

            <Grid Grid.Row="2" Padding="10" Background="#222222">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="📎" Click="AttachFile_Click" Width="44" Height="40"
                        Background="Transparent" Foreground="White" FontSize="18" Padding="0"/>
                <Border x:Name="MicButton" Grid.Column="1" Width="44" Height="40"
                        Background="Transparent" CornerRadius="8"
                        PointerPressed="MicButton_PointerPressed" PointerReleased="MicButton_PointerReleased"
                        PointerExited="MicButton_PointerReleased">
                    <TextBlock Text="🎤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBox x:Name="MessageInput" Grid.Column="2" PlaceholderText="Сообщение..." AcceptsReturn="True" MaxHeight="100" Margin="8,0"/>
                <Button Grid.Column="3" Content="➤" Click="SendMessage_Click" Width="50" Height="40" Background="#0088cc" Foreground="White"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
