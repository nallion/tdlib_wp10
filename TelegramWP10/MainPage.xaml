<Page
    x:Class="TelegramWP10.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TelegramWP10"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <StackPanel x:Name="StartPanel" Padding="20">
            <TextBlock x:Name="StatusText" Text="Загрузка..." Margin="0,0,0,10" Foreground="Gray" TextWrapping="Wrap"/>

            <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                <TextBox x:Name="PhoneInput" Header="Телефон" PlaceholderText="+7..." InputScope="TelephoneNumber"/>
                <Button Content="Далее" Click="SendPhone_Click" HorizontalAlignment="Stretch" Margin="0,10"/>
                <TextBox x:Name="CodeInput" Header="Код" Visibility="Collapsed" Margin="0,10"/>
                <Button x:Name="CodeButton" Content="Войти" Click="SendCode_Click" Visibility="Collapsed" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <ListView x:Name="ChatListView" Height="640" Visibility="Collapsed" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ChatListView_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatItem">
                        <Grid Margin="0,10" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="54" Height="54" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding Photo}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Grid x:Name="MessagesPanel" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Background="#0088cc" Padding="10">
                <Button Content="← Назад" Click="BackButton_Click" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="18"/>
                <TextBlock x:Name="CurrentChatTitle" Text="Имя чата" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
            
            <ListView x:Name="MessagesListView" Grid.Row="1" SelectionMode="None" Padding="10">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:MessageItem">
                        <Border Background="{Binding Background}" Padding="12,8" Margin="0,5" CornerRadius="8" HorizontalAlignment="{Binding Alignment}">
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" MaxWidth="300" Foreground="White" FontSize="16"/>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <Grid Grid.Row="2" Padding="10" Background="#1e1e1e">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MessageInput" PlaceholderText="Написать сообщение..." AcceptsReturn="True" MaxHeight="100"/>
                <Button Grid.Column="1" Content="➤" Click="SendMessage_Click" Margin="10,0,0,0" Width="50" Height="40" Background="#0088cc" Foreground="White"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
