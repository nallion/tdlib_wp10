<StackPanel VerticalAlignment="Center" Padding="20">
    <TextBlock Text="Вход в Telegram" FontSize="24" Margin="0,0,0,20" HorizontalAlignment="Center"/>
    <TextBox x:Name="PhoneInput" Header="Номер телефона" PlaceholderText="+7..." InputScope="TelephoneNumber"/>
    <Button Content="Отправить код" Click="SendCode_Click" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
    <TextBlock x:Name="StatusText" Text="Ожидание..." Margin="0,20,0,0" TextWrapping="Wrap" Foreground="Gray"/>
</StackPanel>
